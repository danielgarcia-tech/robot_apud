name: Daily ApudActa Scraper

on:
  schedule:
    # Eje    - name: 📧 Send daily ZIP to Danielutar todos los días a las 6:00 AM UTC (7:00 AM Madrid en invierno, 8:00 AM en verano)
    - cron: '0 6 * * *'
  workflow_dispatch:  # Permite ejecución manual desde GitHub

# 🔐 CONFIGURACIÓN DE SEGURIDAD
env:
  FORCE_COLOR: 1  # Colores en logs

jobs:
  scrape-apudacta:
    runs-on: ubuntu-latest

    # 🛡️ PERMISOS MÍNIMOS
    permissions:
      contents: read  # Solo leer código
      actions: read   # Leer actions
      # ❌ NO escribir permisos para seguridad

    steps:
    - name: 📥 Checkout repository
      uses: actions/checkout@v4

    - name: 🐍 Set up Python 3.11
      uses: actions/setup-python@v4
      with:
        python-version: '3.11'

    - name: 📦 Install Python dependencies
      run: |
        python -m pip install --upgrade pip
        pip install playwright python-dotenv py7zr

    - name: 🌐 Install Playwright browsers
      run: |
        playwright install chromium

    - name: 🚀 Run ApudActa Scraper
      env:
        EMAIL: ${{ secrets.EMAIL }}
        PASSWORD: ${{ secrets.PASSWORD }}
      run: |
        echo "🌟 Iniciando scraper diario..."
        echo "📧 Usuario: $EMAIL"
        echo "🔐 Password: [PROTEGIDO]"
        python easyday.py
        echo "✅ Scraper completado"

    - name: � Upload downloaded files
      uses: actions/upload-artifact@v4
      if: always()  # Subir archivos aunque haya errores
      with:
        name: apudacta-downloads-${{ github.run_number }}
        path: descargas/
        retention-days: 7  # ⚠️ SOLO 7 DÍAS para seguridad

    - name: �📧 Send daily ZIP to Daniel
      if: success()  # Solo enviar si la descarga fue exitosa
      uses: dawidd6/action-send-mail@v3
      with:
        server_address: smtp-mail.outlook.com
        server_port: 587
        username: ${{ secrets.EMAIL_SENDER }}
        password: ${{ secrets.EMAIL_SENDER_PASSWORD }}
        subject: "📦 ApudActa - Archivo diario $(date +%Y-%m-%d)"
        body: |
          Hola Daniel,

          Adjunto el archivo 7Z descargado automáticamente desde ApudActa.

          **Detalles de la descarga:**
          - Fecha: $(date +%Y-%m-%d)
          - Hora: $(date +%H:%M) UTC
          - Archivo: $(ls descargas/ | head -1 || echo "No se encontró archivo")
          - Tamaño: $(du -h descargas/ | tail -1 | cut -f1 || echo "N/A")

          **🔐 SEGURIDAD DEL ARCHIVO:**
          - El archivo está protegido con contraseña
          - Usa esta contraseña para abrir el 7Z

          Este email fue enviado automáticamente por el scraper de ApudActa.

          Saludos,
          Robot ApudActa 🤖
        to: danielgarcia@ruaabogados.es
        from: ${{ secrets.EMAIL_SENDER }}
        attachments: descargas/*.7z  # Adjuntar todos los archivos 7Z

    - name: 🧹 Cleanup sensitive data
      if: always()
      run: |
        # Limpiar cualquier dato sensible de logs
        echo "🧹 Limpiando datos sensibles..."
        rm -rf descargas/  # Eliminar archivos locales después de subir

    - name: 📧 Send notification when no files found
      if: success() && !hashFiles('descargas/*.7z')
      uses: dawidd6/action-send-mail@v3
      with:
        server_address: smtp-mail.outlook.com
        server_port: 587
        username: ${{ secrets.EMAIL_SENDER }}
        password: ${{ secrets.EMAIL_SENDER_PASSWORD }}
        subject: "⚠️ ApudActa - No se encontraron archivos $(date +%Y-%m-%d)"
        body: |
          Hola Daniel,

          El scraper de ApudActa se ejecutó correctamente pero no encontró archivos para descargar.

          **Posibles razones:**
          - No hay nuevos archivos finalizados en ApudActa
          - Todos los archivos ya fueron descargados anteriormente
          - Problema temporal en la plataforma

          El scraper seguirá funcionando normalmente y te notificará cuando haya archivos disponibles.

          Fecha: $(date +%Y-%m-%d)
          Hora: $(date +%H:%M) UTC

          Saludos,
          Robot ApudActa 🤖
        to: danielgarcia@ruaabogados.es
        from: ${{ secrets.EMAIL_SENDER }}

    - name: 📧 Send notification on failure
      if: failure()
      uses: dawidd6/action-send-mail@v3
      with:
        server_address: smtp-mail.outlook.com
        server_port: 587
        username: ${{ secrets.EMAIL_SENDER }}
        password: ${{ secrets.EMAIL_SENDER_PASSWORD }}
        subject: "❌ Error en ApudActa Scraper - ${{ github.run_number }}"
        body: |
          Hola Daniel,

          Ha ocurrido un error en la ejecución del scraper de ApudActa.

          **Detalles del error:**
          - Fecha: $(date +%Y-%m-%d)
          - Hora: $(date +%H:%M) UTC
          - Run ID: ${{ github.run_id }}

          **Posibles causas:**
          - Problemas de conexión con ApudActa
          - Cambios en la interfaz web
          - Credenciales expiradas
          - Problemas temporales de red

          **Revisar logs:**
          ${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}

          El scraper intentará ejecutarse nuevamente mañana.

          Saludos,
          Robot ApudActa 🤖
        to: danielgarcia@ruaabogados.es
        from: ${{ secrets.EMAIL_SENDER }}